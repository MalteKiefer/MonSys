{
  "name": "mon-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "gen:api-types": "openapi-typescript ../api/openapi.yaml -o src/lib/api-types.generated.ts",
    "verify:api-types": "openapi-typescript ../api/openapi.yaml -o /tmp/api-types.check.ts && diff -u src/lib/api-types.generated.ts /tmp/api-types.check.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lighthouse": "lhci autorun",
    "axe": "axe http://localhost:5173 --exit"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tanstack/react-query": "^5.101.2",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "react-router-dom": "^7.18.1",
    "uplot": "^1.6.32",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.12.1",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.4",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-security": "^4.0.1",
    "http-server": "^14.1.1",
    "openapi-typescript": "^7.4.4",
    "postcss": "^8.5.19",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
